# ─────────────────────────────────────────────────────────────
#  social-mcp-bot  —  Environment Variables
#  Copy this file to .env and fill in your credentials.
# ─────────────────────────────────────────────────────────────

# ── Gemini (required) ─────────────────────────────────────────
# Get your free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Telegram Bot (required) ───────────────────────────────────
# Create a bot via @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# ── social-mcp server path (optional) ────────────────────────
# Path to the compiled social-mcp server, relative to dist/index.js
# Default: ../dist/index.js  (the sibling social-mcp/dist folder)
SOCIAL_MCP_SERVER_PATH=../dist/index.js


# ─────────────────────────────────────────────────────────────
#  Social Media Credentials
#  These are forwarded to the social-mcp server subprocess.
#  Only fill in the platforms you want to use.
# ─────────────────────────────────────────────────────────────

# ── Twitter / X ───────────────────────────────────────────────
# https://developer.twitter.com → your project → OAuth 1.0a
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Discord ───────────────────────────────────────────────────
# https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=

# ── WhatsApp Business ─────────────────────────────────────────
# https://developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Facebook ──────────────────────────────────────────────────
# Graph API Explorer → select Page → generate Page Access Token
FACEBOOK_ACCESS_TOKEN=

# ── Instagram ─────────────────────────────────────────────────
# Instagram Graph API, requires instagram_content_publish scope
INSTAGRAM_ACCESS_TOKEN=

# ── Slack ─────────────────────────────────────────────────────
# https://api.slack.com/apps → OAuth & Permissions → Bot Token
# Required scopes: chat:write, chat:write.public
SLACK_BOT_TOKEN=
