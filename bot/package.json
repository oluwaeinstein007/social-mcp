{
	"name": "social-mcp-bot",
	"version": "1.0.0",
	"description": "Gemini-powered Telegram bot that uses social-mcp tools via MCP",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc && shx chmod +x dist/index.js",
		"start": "node dist/index.js",
		"dev": "tsx watch --clear-screen=false src/index.ts",
		"dev:once": "tsx src/index.ts",
		"kill": "pkill -f 'dist/index.js' || pkill -f 'src/index.ts' || true"
	},
	"dependencies": {
		"@google/genai": "^1.5.0",
		"@modelcontextprotocol/sdk": "^1.12.0",
		"dedent": "^1.7.1",
		"dotenv": "^17.3.1",
		"telegraf": "^4.16.3"
	},
	"devDependencies": {
		"@types/node": "^22.15.19",
		"shx": "^0.3.4",
		"tsx": "^4.19.3",
		"typescript": "^5.8.3"
	}
}
