# ─────────────────────────────────────────────────────────────
#  social-mcp  —  Environment Variables
#  Copy this file to .env and fill in your credentials.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────


# ── TELEGRAM ──────────────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=


# ── TWITTER / X ───────────────────────────────────────────────
# Get from https://developer.twitter.com/en/portal/dashboard
# Requires a project with OAuth 1.0a "Read and Write" permissions
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=


# ── DISCORD ───────────────────────────────────────────────────
# Get from https://discord.com/developers/applications
# Bot → Token  (bot must be invited to your server with Send Messages permission)
DISCORD_BOT_TOKEN=


# ── WHATSAPP BUSINESS ─────────────────────────────────────────
# Get from https://developers.facebook.com/ → your app → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
# Found in Meta Developer console → WhatsApp → API Setup → Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=


# ── FACEBOOK ──────────────────────────────────────────────────
# Get a Page Access Token from https://developers.facebook.com/
# Meta App → Tools → Graph API Explorer → select your Page → Generate Token
FACEBOOK_ACCESS_TOKEN=


# ── INSTAGRAM ─────────────────────────────────────────────────
# Requires Instagram Basic Display API or Graph API
# The token must have instagram_content_publish scope
INSTAGRAM_ACCESS_TOKEN=


# ── SLACK ─────────────────────────────────────────────────────
# Get from https://api.slack.com/apps → your app → OAuth & Permissions
# Required scopes: chat:write, chat:write.public
SLACK_BOT_TOKEN=


# ── LINKEDIN ──────────────────────────────────────────────────
# Get from https://www.linkedin.com/developers/apps → your app → Auth
# Requires an OAuth 2.0 access token with r_liteprofile, w_member_social scopes
LINKEDIN_ACCESS_TOKEN=


# ─────────────────────────────────────────────────────────────
#  TEST RUNNER VARIABLES  (src/run_tools_*.ts)
#  Only needed when running pnpm run:<platform> scripts.
# ─────────────────────────────────────────────────────────────

# ── TELEGRAM TEST ─────────────────────────────────────────────
# Chat ID or @username to send test messages to (your chat or a group)
TEST_TELEGRAM_CHAT_ID=
# Channel ID or @username to query info/members
TEST_TELEGRAM_CHANNEL_ID=
# A known message ID in the chat (for pin test)
TEST_TELEGRAM_MESSAGE_ID=
# Source chat ID for forward test
TEST_TELEGRAM_FROM_CHAT_ID=
# Message ID in the FROM chat to forward
TEST_TELEGRAM_FWD_MESSAGE_ID=

# ── TWITTER TEST ──────────────────────────────────────────────
# Twitter username to look up with GET_USER_INFO (no @ prefix)
TEST_TWITTER_USERNAME=twitter
# Search query for SEARCH_TWEETS
TEST_TWITTER_QUERY=MCP server
# Set to true to actually post a tweet (disabled by default to prevent accidents)
ENABLE_SEND_TWEET=false

# ── DISCORD TEST ──────────────────────────────────────────────
# Channel ID (right-click channel → Copy Channel ID — requires Developer Mode)
TEST_DISCORD_CHANNEL_ID=

# ── WHATSAPP TEST ─────────────────────────────────────────────
# Recipient phone number in E.164 format (e.g. +2348012345678)
TEST_WHATSAPP_TO=

# ── FACEBOOK TEST ─────────────────────────────────────────────
# The numeric ID of the Facebook Page to post to
TEST_FACEBOOK_PAGE_ID=

# ── INSTAGRAM TEST ────────────────────────────────────────────
# Your Instagram Business/Creator account numeric user ID
TEST_INSTAGRAM_USER_ID=
# Publicly accessible image URL to use for the test post
TEST_INSTAGRAM_IMAGE_URL=

# ── SLACK TEST ────────────────────────────────────────────────
# Slack channel ID (C...) or name (#general)
TEST_SLACK_CHANNEL_ID=
